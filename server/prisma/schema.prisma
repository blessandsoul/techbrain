generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  avatarUrl     String?   // SEO-friendly path: /uploads/users/{userId}/avatar/{firstName-lastName}-avatar.webp
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true)
  deletedAt     DateTime?

  // Account lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens RefreshToken[]
  sessions      Session[]
  blockedIps    BlockedIp[]
  articles      Article[]

  // Performance indexes for high-traffic scenarios (10K-100K users/day)
  @@index([role])           // For role-based authorization queries
  @@index([isActive])       // For filtering active/inactive users
  @@index([deletedAt])      // For soft delete filtering
  @@index([email, isActive]) // Compound index for login queries
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(500)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Performance indexes for token operations and cleanup
  @@index([userId])
  @@index([token])
  @@index([userId, expiresAt]) // Compound index for efficient token cleanup queries
  @@index([expiresAt])         // For expired token cleanup cron jobs
  @@map("refresh_tokens")
}

model Session {
  id           String    @id @default(uuid())
  userId       String
  deviceInfo   String?   @db.VarChar(500) // User agent, device type
  ipAddress    String?   @db.VarChar(45)  // IPv4 or IPv6
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Performance indexes for session queries
  @@index([userId])
  @@index([userId, expiresAt])
  @@index([expiresAt])         // For expired session cleanup
  @@map("sessions")
}

model BlockedIp {
  id        String   @id @default(uuid())
  ip        String   @unique @db.VarChar(45)
  reason    String?  @db.VarChar(500)
  blockedBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [blockedBy], references: [id])

  @@index([ip])
  @@map("blocked_ips")
}

// ── Products & Catalog ─────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  slug      String   @unique @db.VarChar(100)
  nameKa    String   @db.VarChar(200)
  nameRu    String   @default("") @db.VarChar(200)
  nameEn    String   @default("") @db.VarChar(200)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductCategory[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("categories")
}

model Product {
  id            String    @id @default(uuid())
  slug          String    @unique
  price         Float     @default(0)
  originalPrice Float?
  currency      String    @default("GEL") @db.VarChar(10)
  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  images        Json      @default("[]")
  nameKa        String    @db.VarChar(500)
  nameRu        String    @default("") @db.VarChar(500)
  nameEn        String    @default("") @db.VarChar(500)
  descriptionKa String?   @db.Text
  descriptionRu String?   @db.Text
  descriptionEn String?   @db.Text
  content       String?   @db.LongText
  relatedProducts Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  specs      ProductSpec[]
  categories ProductCategory[]
  orderItems OrderItem[]

  @@index([isActive])
  @@index([isFeatured])
  @@index([isActive, isFeatured])
  @@index([price])
  @@map("products")
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@index([productId])
  @@map("product_categories")
}

model ProductSpec {
  id        String @id @default(uuid())
  productId String
  keyKa     String @db.VarChar(200)
  keyRu     String @default("") @db.VarChar(200)
  keyEn     String @default("") @db.VarChar(200)
  value     String @db.VarChar(500)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([keyKa, value])
  @@index([productId, keyKa])
  @@map("product_specs")
}

model CatalogConfig {
  id         String   @id @default("singleton")
  categories Json
  filters    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("catalog_config")
}

// ── Projects & Site Settings ─────────────────────────────────

model Project {
  id         String   @id @default(uuid())
  slug       String   @unique @db.VarChar(300)
  titleKa    String   @db.VarChar(500)
  titleRu    String   @default("") @db.VarChar(500)
  titleEn    String   @default("") @db.VarChar(500)
  excerptKa  String   @default("") @db.VarChar(1000)
  excerptRu  String   @default("") @db.VarChar(1000)
  excerptEn  String   @default("") @db.VarChar(1000)
  locationKa String   @db.VarChar(500)
  locationRu String   @default("") @db.VarChar(500)
  locationEn String   @default("") @db.VarChar(500)
  type       String   @db.VarChar(50)
  cameras    Int      @default(0)
  image      String?  @db.VarChar(500)
  content    String   @default("") @db.LongText
  year       String   @db.VarChar(10)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([sortOrder])
  @@index([slug])
  @@map("projects")
}

model SiteSetting {
  id        String   @id @default("singleton")
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ── Orders ──────────────────────────────────────────────

enum OrderStatus {
  NEW
  CONTACTED
  COMPLETED
}

model Order {
  id            String      @id @default(uuid())
  customerName  String      @db.VarChar(100)
  customerPhone String      @db.VarChar(30)
  locale        String      @default("ka") @db.VarChar(5)
  total         Float       @default(0)
  status        OrderStatus @default(NEW)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items OrderItem[]
  notes OrderNote[]

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String
  productId    String?
  productName  String  @db.VarChar(500)
  productImage String? @db.VarChar(500)
  productSlug  String? @db.VarChar(300)
  quantity     Int
  unitPrice    Float

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderNote {
  id        String   @id @default(uuid())
  orderId   String
  content   String   @db.Text
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_notes")
}

// ── Inquiries (Contact Form) ────────────────────────────

model Inquiry {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  phone     String   @db.VarChar(30)
  message   String   @db.Text
  locale    String   @default("ka") @db.VarChar(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@map("inquiries")
}

// ── Articles / Blog ──────────────────────────────────────

model Article {
  id          String   @id @default(uuid())
  slug        String   @unique @db.VarChar(300)
  title       String   @db.VarChar(500)
  excerpt     String   @db.Text
  content     String   @db.LongText              // raw MDX
  category    String   @db.VarChar(50)           // cameras | nvr | installation | news | guides
  coverImage  String?  @db.VarChar(500)          // /uploads/articles/{id}/cover.webp
  isPublished Boolean  @default(false)
  readMin     Int      @default(5)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([isPublished, createdAt])
  @@index([slug])
  @@index([category])
  @@index([authorId])
  @@map("articles")
}
